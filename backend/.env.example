# ============================================================================
# Project Synapse — Backend configuration (Go ingestion + graph + RAG server)
# Copy to `.env` and adjust. All keys are read from the environment by
# internal/config; the values below are the built-in defaults.
#
# ⚠ NEVER commit a real `.env` — it is gitignored. Only this template (with
#   empty secret values) is tracked.
# ============================================================================

# --- Database (PostgreSQL + pgvector) ---------------------------------------
# pgx connection string. Matches the docker-compose container (synapse/synapse).
SYNAPSE_DATABASE_URL=postgres://synapse:synapse@localhost:5432/synapse?sslmode=disable

# --- Ingestion --------------------------------------------------------------
# Directory to walk + ingest. Leave empty to skip ingestion and only serve the
# API. Example: an absolute path to a TS/JS/Go/Rust repo, or testdata/mockproject.
SYNAPSE_INGEST_ROOT=

# Worker-pool size for the ingestion pipeline (parse + persist concurrency).
# Lower this (e.g. 3) if a hosted embedding provider rate-limits you (HTTP 429).
SYNAPSE_WORKERS=4

# Run the chunk + embed enrichment pass during ingestion (semantic layer).
SYNAPSE_ENRICH=true
# Add an LLM-written one-line "purpose" per symbol, embedded alongside the code
# to sharpen semantic retrieval. Costs one LLM call per file. Needs an LLM key.
SYNAPSE_ENRICH_SUMMARIES=true

# --- Parser (Node sub-process for TypeScript/JavaScript) --------------------
# Directory containing parse.mjs and its local `typescript` install, relative to
# the backend working directory. Go (.go) and Rust (.rs) are parsed in-process.
SYNAPSE_PARSER_DIR=tools/tsparser
SYNAPSE_NODE_BIN=node

# --- HTTP server ------------------------------------------------------------
SYNAPSE_HTTP_ADDR=:8080
# Start the HTTP API after ingestion (set false for ingest-only batch runs).
SYNAPSE_SERVE=true

# --- Embeddings (semantic layer) --------------------------------------------
# Provider: auto | deterministic | jina | voyage | openai | openrouter | gemini | ollama
#   auto          -> first configured of openai → openrouter → gemini → ollama,
#                    else deterministic (offline). Targets 768 dims.
#   deterministic -> local hashing embedder, no network/key required (768).
#   jina          -> jina-embeddings-v2-base-code (768, code-specialized).
#   voyage        -> voyage-code-3 (1024; needs SYNAPSE_EMBED_DIM=1024 + matching column).
#   openai        -> text-embedding-3-small.
#   openrouter    -> OpenAI-compatible embeddings via OpenRouter.
#   gemini        -> Google text-embedding-004.
#   ollama        -> nomic-embed-text (768; requires a local Ollama).
SYNAPSE_EMBED_PROVIDER=auto
# Override the embedding model name (provider-specific). Empty = provider default.
SYNAPSE_EMBED_MODEL=
# Embedding vector dimension — set to the chosen model's output size:
#   1024 -> mxbai-embed-large (ollama, free), voyage-code-3, openai text-embedding-3-* (dimensions=1024)
#   768  -> jina, nomic-embed-text, gemini @768
# The backend auto-migrates the vector_chunks column + HNSW index to this value on
# startup (clearing stale vectors), so changing the model/dim only needs a restart
# + a re-ingest — no manual SQL or schema edit. VECTOR(n) in schema.sql is just the
# initial default for a fresh database.
SYNAPSE_EMBED_DIM=1024

# Embedding provider keys (set only the one(s) you use; leave the rest empty).
JINA_API_KEY=
JINA_BASE_URL=
VOYAGE_API_KEY=
VOYAGE_BASE_URL=
GEMINI_API_KEY=
GEMINI_BASE_URL=
# Ollama host (only used when SYNAPSE_EMBED_PROVIDER=ollama).
OLLAMA_HOST=http://localhost:11434

# --- LLM (answer synthesis, docs, architecture, Tier-2 bug analysis) --------
# Provider: auto | template | anthropic | openai | openrouter | ollama
#   auto      -> anthropic → openai → openrouter if a key is set, else template.
#   anthropic -> Claude Messages API (default model claude-opus-4-8).
#   openai    -> chat completions (default gpt-4o).
#   openrouter-> OpenAI-compatible chat via OpenRouter (many models).
#   template  -> offline deterministic responder (no key required).
SYNAPSE_LLM_PROVIDER=auto
# Override the chat model id. Empty = provider default.
SYNAPSE_LLM_MODEL=
# Optional per-engine model overrides for the heavier reasoning tasks. Same
# provider as above; empty = reuse SYNAPSE_LLM_MODEL. Use these to run docs,
# architecture, and the Tier-2 bug analysis on a stronger model (e.g. gpt-4o)
# while the assistant / blueprint / tours stay on the cheaper base model.
SYNAPSE_DOCS_MODEL=
SYNAPSE_ARCH_MODEL=
SYNAPSE_BUGS_MODEL=

# LLM provider keys (leave empty to run offline with the template responder).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=

# --- RAG + blueprint tuning -------------------------------------------------
SYNAPSE_RAG_TOPK=5
SYNAPSE_BLUEPRINT_CONCURRENCY=6

# --- Bug & anti-pattern detection (/api/bugs) -------------------------------
# Tier 1 (graph + code scans) always runs. Heuristic candidates (resource leaks,
# bad practices) are then confirmed against their real code by an LLM verify pass;
# Tier 2 is the adversarial deep-bug pass on the riskiest nodes.
SYNAPSE_BUGS_LLM=true
# Cap on files sent to the Tier-2 LLM per scan (token budget).
SYNAPSE_BUGS_MAX_LLM=8

# --- Dead-code pruning (/api/prune) -----------------------------------------
# LLM-verify file-level dead-code candidates to drop framework-invoked /
# dynamically-loaded false positives (e.g. Next.js pages, route handlers).
SYNAPSE_PRUNE_VERIFY=true

# --- Repository ingestion (POST /api/ingest clone-on-demand) ----------------
SYNAPSE_CLONES_DIR=.synapse-clones
SYNAPSE_GIT_BIN=git

# --- Auth (OAuth lives in the Next.js front-end; see frontend/.env.example) --
# Surfaced here for env parity / future server-side session validation.
AUTH_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
