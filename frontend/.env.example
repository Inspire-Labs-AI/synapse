# ============================================================================
# Project Synapse — Frontend (Next.js) environment
# Copy to `.env.local` and adjust. Everything here has a working local default,
# so the app runs with NO configuration for local development.
# ============================================================================

# --- Backend API ------------------------------------------------------------
# Base URL of the Go backend. Defaults to the local dev server if unset.
NEXT_PUBLIC_SYNAPSE_API=http://localhost:8080

# --- Auth.js (next-auth v5) -------------------------------------------------
# Session-signing secret. A dev fallback is used if unset, but you MUST set a
# strong random value in any non-local deployment. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=

# --- OAuth providers (optional) ---------------------------------------------
# The "Continue as Local Developer" sign-in always works without these.
# Fill a pair in to enable that provider's button (register an OAuth app first).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
